#include <stdio.h>
void reverse_array(int arr[], int n) {
    int start = 0;
    int end = n - 1;
    int temp;
    while (start < end) {
        temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;
        start++;
        end--;
    }
}
int main() {
    int n, i;
    scanf("%d", &n);
    int arr[n];
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    reverse_array(arr, n);
    for (i = 0; i < n; i++) {
        printf("%d", arr[i]);
        if (i < n - 1) { 
            printf(" ");
        }
    }
    printf("\n");

    return 0;
}
