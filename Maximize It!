from itertools import product

def maximize_modulo(n, m, lists):
    max_value = 0
    
    # Generate all combinations of picking one element from each list
    for combination in product(*lists):
        # Calculate the sum of squares
        sum_of_squares = sum(x ** 2 for x in combination)
        # Calculate the modulo
        current_value = sum_of_squares % m
        # Update the maximum value found
        max_value = max(max_value, current_value)
    
    return max_value

if __name__ == '__main__':
    # Read input
    first_line = input().strip().split()
    n = int(first_line[0])  # number of lists
    m = int(first_line[1])  # modulo value
    
    lists = []
    for _ in range(n):
        line = list(map(int, input().strip().split()))
        lists.append(line[1:])  # Append the elements of the list (ignore the first number)
    
    # Get the result
    result = maximize_modulo(n, m, lists)
    
    # Print the result
    print(result)
